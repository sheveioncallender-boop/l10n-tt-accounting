<odoo>
    <record id="view_company_form_l10n_tt" model="ir.ui.view">
        <field name="name">res.company.form.l10n.tt</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Trinidad &amp; Tobago">
                    <group>
                        <group string="Statutory Details">
                            <field name="l10n_tt_bir_number"/>
                            <field name="l10n_tt_vat_number"/>
                            <field name="l10n_tt_enable_vat"/>
                            <field name="l10n_tt_default_vat_rate"/>
                            <field name="l10n_tt_company_registration_number"/>
                            <field name="l10n_tt_paye_registration_number"/>
                            <field name="l10n_tt_nis_employer_number"/>
                            <field name="l10n_tt_business_activity"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
