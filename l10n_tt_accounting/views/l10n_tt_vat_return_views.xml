<odoo>
    <record id="view_l10n_tt_vat_return_list" model="ir.ui.view">
        <field name="name">l10n.tt.vat.return.list</field>
        <field name="model">l10n.tt.vat.return</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <field name="output_vat_amount"/>
                <field name="input_vat_amount"/>
                <field name="net_vat_payable"/>
                <field name="payments_made"/>
                <field name="balance_due"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_tt_vat_return_form" model="ir.ui.view">
        <field name="name">l10n.tt.vat.return.form</field>
        <field name="model">l10n.tt.vat.return</field>
        <field name="arch" type="xml">
            <form string="Trinidad VAT Return">
                <header>
                    <button name="action_refresh_amounts" type="object" string="Refresh Amounts" class="btn-secondary"/>
                    <button name="action_mark_ready" type="object" string="Ready to File" invisible="state != 'draft'"/>
                    <button name="action_mark_filed" type="object" string="Mark Filed" invisible="state not in ('draft','ready')"/>
                    <button name="action_mark_paid" type="object" string="Mark Paid" invisible="state not in ('filed','ready')"/>
                    <button name="action_close" type="object" string="Close" invisible="state not in ('paid','filed')"/>
                    <button name="action_reset_draft" type="object" string="Reset to Draft" invisible="state == 'draft'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,ready,filed,paid,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Period">
                            <field name="company_id"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group string="VAT Accounts">
                            <field name="output_vat_account_id"/>
                            <field name="input_vat_account_id"/>
                            <field name="vat_control_account_id"/>
                            <field name="bir_partner_id"/>
                        </group>
                    </group>

                    <group string="VAT Summary">
                        <group>
                            <field name="output_vat_amount" readonly="1"/>
                            <field name="input_vat_amount" readonly="1"/>
                            <field name="import_vat_amount" readonly="1"/>
                        </group>
                        <group>
                            <field name="net_vat_payable" readonly="1"/>
                            <field name="payments_made" readonly="1"/>
                            <field name="balance_due" readonly="1"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Linked VAT Payments">
                            <p>
                                Link cheque, bank, or journal lines that represent payments made to BIR for this VAT period.
                                This does not change Odoo's accounting flow; it only lets the Trinidad VAT Return track payments against the period.
                            </p>
                            <field name="payment_move_line_ids">
                                <list>
                                    <field name="date"/>
                                    <field name="move_name"/>
                                    <field name="journal_id"/>
                                    <field name="partner_id"/>
                                    <field name="account_id"/>
                                    <field name="debit"/>
                                    <field name="credit"/>
                                    <field name="balance"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_tt_vat_return_search" model="ir.ui.view">
        <field name="name">l10n.tt.vat.return.search</field>
        <field name="model">l10n.tt.vat.return</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="company_id"/>
                <field name="date_from"/>
                <field name="date_to"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="filed" string="Filed" domain="[('state','=','filed')]"/>
                <filter name="paid" string="Paid" domain="[('state','=','paid')]"/>
            </search>
        </field>
    </record>

    <record id="action_l10n_tt_vat_return" model="ir.actions.act_window">
        <field name="name">Trinidad VAT Returns</field>
        <field name="res_model">l10n.tt.vat.return</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'default_company_id': allowed_company_ids[0]}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a VAT return period to summarize VAT collected, VAT claimable, VAT paid, and balance due.</p>
        </field>
    </record>
</odoo>
