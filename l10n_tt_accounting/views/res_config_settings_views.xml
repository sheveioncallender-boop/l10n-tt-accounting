<odoo>
    <record id="res_config_settings_view_form_l10n_tt" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.l10n.tt</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Trinidad &amp; Tobago" name="l10n_tt_accounting" groups="account.group_account_manager">
                    <block title="Trinidad &amp; Tobago Ready Setup" name="l10n_tt_ready_setup">
                        <setting string="Apply Trinidad Setup" help="Sets country, fiscal country, TTD currency, VAT 12.5%, default taxes, journals, and Trinidad chart accounts for this company.">
                            <button name="action_apply_l10n_tt_setup" type="object" string="Apply / Refresh Trinidad Setup" class="btn-primary"/>
                            <button name="action_open_l10n_tt_setup" type="object" string="Open Bank Setup" class="btn-secondary"/>
                        </setting>
                        <setting string="Company Defaults" help="These values should show Trinidad &amp; Tobago and TTD after setup is applied.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="l10n_tt_country_id" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_country_id" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="l10n_tt_currency_id" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_currency_id" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="VAT Details" help="Stores the Trinidad VAT defaults used by the localization setup.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="l10n_tt_enable_vat" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_enable_vat"/>
                                </div>
                                <div class="row">
                                    <label for="l10n_tt_default_vat_rate" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_default_vat_rate" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                        <setting string="Statutory Details" help="Company BIR and VAT registration details for Trinidad &amp; Tobago.">
                            <div class="content-group">
                                <div class="row mt16">
                                    <label for="l10n_tt_bir_number" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_bir_number" class="oe_inline"/>
                                </div>
                                <div class="row">
                                    <label for="l10n_tt_vat_number" class="col-lg-4 o_light_label"/>
                                    <field name="l10n_tt_vat_number" class="oe_inline"/>
                                </div>
                            </div>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
