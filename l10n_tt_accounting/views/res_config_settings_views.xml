<odoo>
    <record id="res_config_settings_view_form_l10n_tt" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.l10n.tt.safe.compatible</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app string="Trinidad &amp; Tobago" name="l10n_tt_accounting" groups="account.group_account_manager">
                    <block title="Trinidad &amp; Tobago Localization" name="l10n_tt_localization">
                        <setting string="Trinidad &amp; Tobago Setup"
                                 help="Open the safe setup assistant. This does not replace Odoo or Odoo Mates Accounting.">
                            <button name="action_l10n_tt_open_setup"
                                    type="object"
                                    string="Open Trinidad Setup"
                                    class="btn-primary"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>
</odoo>
